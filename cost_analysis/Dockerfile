FROM python:3.11-slim

WORKDIR /app

ARG VERSION=unknown
ENV APP_VERSION=$VERSION

# –Ъ–Њ–њ–Є—А—Г–µ–Љ requirements.txt (–Њ–љ –≤ –њ–∞–њ–Ї–µ app —А–µ–њ–Њ–Ј–Є—В–Њ—А–Є—П)
COPY app/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# –Ъ–Њ–њ–Є—А—Г–µ–Љ –Т–°–Х —Д–∞–є–ї—Л –Є–Ј –њ–∞–њ–Ї–Є app —А–µ–њ–Њ–Ј–Є—В–Њ—А–Є—П –≤ /app
COPY app/ ./

# –°–Њ–Ј–і–∞–µ–Љ –њ–Њ–ї—М–Ј–Њ–≤–∞—В–µ–ї—П
RUN useradd -m -s /bin/bash appuser && \
    chown -R appuser:appuser /app
USER appuser

EXPOSE 5000

CMD ["python", "-m", "app"]
